    ]
  },
  "name": "rekrutteringsbistand",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "sharp",
      "unrs-resolver"
    ]
  },
  "private": true,
  "scripts": {
    "1. Start dev": "run-p dev open:dev",
    "2. Start storybook": "storybook dev -p 6006",
    "3. Start test-dev": "run-p test-dev open:dev",
    "4. Kjør playwright tester": "pnpm test",
    "5. Kjør test generator": "pnpm exec playwright codegen --viewport-size=1920,1080",
    "6. Kjør precommit": "run-p formater-kode  type-check lint",
    "a11y": "PUPPETEER_EXECUTABLE_PATH=$(node -e \"console.log(require('@playwright/test').chromium.executablePath())\") pa11y-ci",
    "build": "next build",
    "build-storybook": "rm -rf storybook-static && storybook build --output-dir storybook-static",
    "dev": "next dev -p 1337 | pino-pretty",
    "formater-kode": "prettier --write .",
    "lint": "eslint",
    "open:dev": "open http://localhost:1337",
    "test": "playwright test",
    "test-dev": "NEXT_PUBLIC_PLAYWRIGHT_TEST_MODE=true next dev -p 1337",
    "type-check": "tsc --noEmit",
    "ubrukt kode": "knip --config ./knip.json",
    "ubrukte typer": "ts-unused-exports tsconfig.unused.json"
  },
  "version": "0.1.0"
}
